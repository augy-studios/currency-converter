{
    "name": "Currency Converter by UwU Apps",
    "short_name": "Currency Converter",
    "description": "A simple currency converter, converting currencies has never been easier!",
    "icons": [{
            "src": "CC-192.png",
            "type": "image/png",
            "sizes": "192x192"
        },
        {
            "src": "CC-512.png",
            "type": "image/png",
            "sizes": "512x512"
        }
    ],
    "screenshots": [{
            "src": "/images/screenshot_1.png",
            "type": "image/png",
            "sizes": "1080x2340",
            "form_factor": "narrow"
        },
        {
            "src": "/images/screenshot_2.png",
            "type": "image/png",
            "sizes": "1920x988",
            "form_factor": "wide"
        }
    ],
    "start_url": "/",
    "theme_color": "#cfc",
    "background_color": "#cfc",
